<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        android:padding="0dp"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/invite_member"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/input_label"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/input_border"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etInviteEmail"
            style="@style/DarkEditText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Nhập email người dùng"
            android:textSize="14sp"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:singleLine="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSendInvite"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Gửi lời mời"
        android:textColor="@color/white"
        android:background="@drawable/bg_button_dark"
        android:stateListAnimator="@null"
        android:layout_marginTop="32dp" />

</LinearLayout>
