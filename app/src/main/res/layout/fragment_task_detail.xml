<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header with Back and Edit -->
    <RelativeLayout
        android:id="@+id/rlHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/ivEditTask"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:padding="4dp"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            app:tint="@color/white" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rlHeader"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="50dp">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Check"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:text="Lam lung vat va roi den gio kiem tra thoi"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <!-- Status and Check Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTaskStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rect_dark"
                    android:backgroundTint="#1B2530"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="ĐANG LÀM"
                    android:textColor="#5995D5"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivConfirmStatus"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="20dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_check_circle_custom"
                    app:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- Info Rows -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Người giao"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical">
                        <ImageView
                            android:id="@+id/ivCreatorAvatar"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_user_default"
                            app:tint="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvCreatorName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="phuc"
                            android:textColor="@color/white"
                            android:textSize="18sp" />
                    </LinearLayout>
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:text="Ngày giao"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvStartDate"
                        android:gravity="end"
                        android:text="10h58 Th 7 28/03/2026"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:text="Hạn"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvEndDate"
                        android:gravity="end"
                        android:text="10h58 CN 29/03/2026"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:text="Người được giao"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical">
                        <ImageView
                            android:id="@+id/ivAssigneeAvatar"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_user_default"
                            app:tint="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvAssigneeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Phuc1"
                            android:textColor="@color/white"
                            android:textSize="18sp" />
                    </LinearLayout>
                </TableRow>

                <!-- Points Row - Added ID for hiding -->
                <TableRow
                    android:id="@+id/trPoints"
                    android:layout_marginBottom="32dp">
                    <TextView
                        android:text="Điểm"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <LinearLayout
                        android:id="@+id/llPointsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/llPointsSelector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:visibility="gone">
                            <TextView
                                android:id="@+id/btnMinusPoint"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="−"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvRewardPoints"
                                android:layout_width="70dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/btnPlusPoint"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="+"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRewardPointsStatic"
                            android:layout_width="90dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_rect_dark"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="điểm"
                            android:textColor="@color/text_secondary"
                            android:textSize="18sp" />
                    </LinearLayout>
                </TableRow>
            </TableLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
