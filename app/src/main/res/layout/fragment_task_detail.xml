<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header with Back and Edit -->
    <RelativeLayout
        android:id="@+id/rlHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/ivEditTask"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:padding="4dp"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/rlHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Check"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:text="@string/hint_task_description"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <!-- Status, Repeat Icon and Check Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTaskStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rect_dark"
                    android:backgroundTint="#1B2530"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="@string/status_doing"
                    android:textColor="#5995D5"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivRepeatDetail"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_repeat"
                    android:visibility="gone"
                    app:tint="#59D595" />

                <ImageView
                    android:id="@+id/ivConfirmStatus"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="20dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_check_circle_custom"
                    app:tint="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- Info Rows -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:text="@string/label_created_by"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical">
                        <ImageView
                            android:id="@+id/ivCreatorAvatar"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_user_default"
                            app:tint="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tvCreatorName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="---"
                            android:textColor="@color/white"
                            android:textSize="18sp" />
                    </LinearLayout>
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:gravity="start"
                        android:text="@string/label_start_date"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvStartDate"
                        android:gravity="end"
                        android:text="---"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:gravity="start"
                        android:text="@string/label_end_date"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvEndDate"
                        android:gravity="end"
                        android:text="---"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </TableRow>

                <!-- New Row for Weekly Repeat Days -->
                <TableRow
                    android:id="@+id/trRepeatDays"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone">
                    <TextView
                        android:gravity="start"
                        android:text="@string/label_select_days"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/tvRepeatDays"
                        android:gravity="end"
                        android:text="---"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </TableRow>

                <TableRow android:layout_marginBottom="32dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="start|top"
                        android:layout_marginTop="4dp"
                        android:text="@string/label_assigned_to"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <LinearLayout
                        android:id="@+id/llAssigneesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">
                        <!-- Items will be added dynamically in code -->
                    </LinearLayout>
                </TableRow>

                <!-- Points Row -->
                <TableRow
                    android:id="@+id/trPoints"
                    android:layout_marginBottom="32dp">
                    <TextView
                        android:gravity="start"
                        android:text="@string/tab_point"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp" />
                    <LinearLayout
                        android:id="@+id/llPointsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/llPointsSelector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:visibility="gone">
                            <TextView
                                android:id="@+id/btnMinusPoint"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="−"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvRewardPoints"
                                android:layout_width="48dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/btnPlusPoint"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_rect_dark"
                                android:gravity="center"
                                android:text="+"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRewardPointsStatic"
                            android:layout_width="60dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_rect_dark"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/tab_point"
                            android:textColor="@color/white"
                            android:textSize="18sp" />
                    </LinearLayout>
                </TableRow>
            </TableLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
