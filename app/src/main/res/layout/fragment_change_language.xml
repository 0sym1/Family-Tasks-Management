<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/select_language_title"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Vietnamese Option -->
    <LinearLayout
        android:id="@+id/btnLangVi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <RadioButton
            android:id="@+id/rbVi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:buttonTint="@color/white" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvVi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_vietnamese"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckVi"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- English Option -->
    <LinearLayout
        android:id="@+id/btnLangEn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLangVi">

        <RadioButton
            android:id="@+id/rbEn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:buttonTint="@color/text_secondary" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvEn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_english"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckEn"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- French Option -->
    <LinearLayout
        android:id="@+id/btnLangFr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLangEn">

        <RadioButton
            android:id="@+id/rbFr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:buttonTint="@color/text_secondary" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvFr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_french"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckFr"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Chinese Option -->
    <LinearLayout
        android:id="@+id/btnLangZh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLangFr">

        <RadioButton
            android:id="@+id/rbZh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/text_secondary"
            android:clickable="false" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvZh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_chinese"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckZh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Korean Option -->
    <LinearLayout
        android:id="@+id/btnLangKo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLangZh">

        <RadioButton
            android:id="@+id/rbKo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/text_secondary"
            android:clickable="false" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvKo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_korean"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckKo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Russian Option -->
    <LinearLayout
        android:id="@+id/btnLangRu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnLangKo">

        <RadioButton
            android:id="@+id/rbRu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/text_secondary"
            android:clickable="false" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <TextView
            android:id="@+id/tvRu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lang_russian"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivCheckRu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#2C2C2C"
        android:text="@string/btn_save"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnLangRu" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#2C2C2C"
        android:text="@string/btn_cancel"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSave" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
