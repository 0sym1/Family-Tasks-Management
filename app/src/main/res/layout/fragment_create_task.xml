<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/create_task"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <!-- Tiêu đề -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Tiêu đề"
            android:textColor="@color/input_label"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/input_border"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etTaskTitle"
            style="@style/DarkEditText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Nhập tiêu đề nhiệm vụ"
            android:textSize="14sp"
            android:autofillHints=""
            android:singleLine="true" />
    </LinearLayout>

    <!-- Mô tả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Mô tả"
            android:textColor="@color/input_label"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/input_border"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etTaskDescription"
            style="@style/DarkEditText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Nhập mô tả (tuỳ chọn)"
            android:textSize="14sp"
            android:autofillHints=""
            android:singleLine="true" />
    </LinearLayout>

    <!-- Điểm thưởng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Điểm thưởng"
            android:textColor="@color/input_label"
            android:textSize="14sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/input_border"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etRewardPoints"
            style="@style/DarkEditText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="0"
            android:textSize="14sp"
            android:inputType="number"
            android:autofillHints=""
            android:singleLine="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCreateTask"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/create_task"
        android:textColor="@color/white"
        android:background="@drawable/bg_button_dark"
        android:stateListAnimator="@null"
        android:layout_marginTop="16dp" />

</LinearLayout>
