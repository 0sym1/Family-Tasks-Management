<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="80dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_welcome"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_workspace_description"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Normal View: Search and Add Button -->
            <LinearLayout
                android:id="@+id/llNormalHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/ivSearchIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#666666" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/ivSearchIcon"
                        android:background="@null"
                        android:hint="@string/hint_search_workspace"
                        android:textColorHint="#666666"
                        android:textColor="@color/white"
                        android:paddingStart="12dp"
                        android:textSize="15sp"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />
                </RelativeLayout>

                <Button
                    android:id="@+id/btnAddWorkspace"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_plus"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="24dp" />
            </LinearLayout>

            <!-- Add Workspace View: Minus Button and Form -->
            <LinearLayout
                android:id="@+id/llAddWorkspaceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnCancelAdd"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_minus_btn"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        paddingStart="12dp"
                        paddingEnd="12dp"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_workspace_name"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="20dp"
                            android:background="#444444"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp" />

                        <EditText
                            android:id="@+id/etNewWorkspaceName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="@string/hint_enter_workspace_name"
                            android:textColorHint="#666666"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:inputType="text" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSubmitAdd"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_add"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_button_dark"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Container for Workspace Cards -->
            <LinearLayout
                android:id="@+id/llWorkspaceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWorkspace1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp">

                            <TextView
                                android:id="@+id/tvWorkspaceName1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/llOptions"
                                android:text="@string/workspace_name_demo"
                                android:textColor="@color/white"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/llOptions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btnDelete1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:minWidth="60dp"
                                    android:text="@string/btn_delete"
                                    android:textSize="12sp"
                                    android:background="@drawable/bg_button_dark"
                                    android:textColor="@color/white"
                                    android:stateListAnimator="@null"
                                    android:layout_marginEnd="10dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvOptions1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⋯"
                                    android:textColor="@color/white"
                                    android:textSize="26sp"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </RelativeLayout>

                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:progress="65"
                            android:max="100"
                            android:indeterminate="false"
                            android:progressDrawable="@drawable/progress_horizontal" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#333333"
                            android:layout_marginTop="20dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/access"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:padding="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWorkspace2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp">

                            <TextView
                                android:id="@+id/tvWorkspaceName2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:text="@string/workspace_name_demo"
                                android:textColor="@color/white"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/llOptions2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btnDelete2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:minWidth="60dp"
                                    android:text="@string/btn_delete"
                                    android:textSize="12sp"
                                    android:background="@drawable/bg_button_dark"
                                    android:textColor="@color/white"
                                    android:stateListAnimator="@null"
                                    android:layout_marginEnd="10dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvOptions2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⋯"
                                    android:textColor="@color/white"
                                    android:textSize="26sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </RelativeLayout>

                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:progress="40"
                            android:max="100"
                            android:indeterminate="false"
                            android:progressDrawable="@drawable/progress_horizontal" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#333333"
                            android:layout_marginTop="20dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/access"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:padding="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWorkspace3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/input_bg"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvWorkspaceName3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="@string/workspace_name_demo"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/llOptions3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnDelete3"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:minWidth="60dp"
                                android:text="@string/btn_delete"
                                android:textSize="12sp"
                                android:background="@drawable/bg_button_dark"
                                android:textColor="@color/white"
                                android:stateListAnimator="@null"
                                android:layout_marginEnd="10dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvOptions3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⋯"
                                android:textColor="@color/white"
                                android:textSize="26sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </RelativeLayout>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:progress="80"
                        android:max="100"
                        android:indeterminate="false"
                        android:progressDrawable="@drawable/progress_horizontal" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#333333"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/access"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:padding="16dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/input_bg"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:labelVisibilityMode="labeled" />
</LinearLayout>