<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_back"
        android:contentDescription="Back"
        android:layout_marginBottom="20dp"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history_title"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <!-- Filter Tabs (Using HorizontalScrollView + Buttons for custom style) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTabAll"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="@string/tab_all"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_dark"
                android:paddingHorizontal="24dp"
                android:layout_marginEnd="12dp"
                style="?android:attr/borderlessButtonStyle"/>

            <Button
                android:id="@+id/btnTabTask"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="@string/tab_task"
                android:textAllCaps="false"
                android:textColor="#888888"
                android:background="@android:color/transparent"
                android:paddingHorizontal="24dp"
                android:layout_marginEnd="12dp"
                style="?android:attr/borderlessButtonStyle"/>

            <Button
                android:id="@+id/btnTabPoint"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="@string/tab_point"
                android:textAllCaps="false"
                android:textColor="#888888"
                android:background="@android:color/transparent"
                android:paddingHorizontal="24dp"
                style="?android:attr/borderlessButtonStyle"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- History List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"/>

</LinearLayout>