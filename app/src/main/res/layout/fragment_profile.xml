<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header with Title and Language -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_title"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_button_dark"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_profile"
                    android:tint="@color/white"
                    android:contentDescription="@string/profile_language"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_language_vi"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_home"
                    android:tint="@color/text_hint"
                    android:contentDescription="@string/profile_language" />

            </LinearLayout>

        </LinearLayout>

        <!-- Avatar Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_user_default"
                android:contentDescription="@string/profile_avatar"
                android:scaleType="centerCrop"
                android:layout_gravity="center" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/white"
                android:contentDescription="@string/profile_edit_avatar"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp" />

        </FrameLayout>

        <!-- User Info -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nguyen Tuan Ngoc"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@Tuan Ngoc"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginEnd="16dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="@color/divider"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_points_default"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp" />

        <!-- Password Change Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_change_password"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etOldPassword"
            style="@style/DarkEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/profile_old_password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_field" />

        <EditText
            android:id="@+id/etNewPassword"
            style="@style/DarkEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/profile_new_password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_field" />

        <EditText
            android:id="@+id/etConfirmPassword"
            style="@style/DarkEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/profile_confirm_password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input_field" />

        <!-- Language Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_language"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnLanguageVi"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🇻🇳 Tiếng Việt"
                android:textColor="@color/white"
                android:background="@drawable/bg_button_dark"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnLanguageEn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🇬🇧 English"
                android:textColor="@color/white"
                android:background="@drawable/bg_button_dark"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/profile_save"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_dark"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/profile_logout"
            android:textColor="@color/text_error"
            android:background="@drawable/bg_button_dark"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>

