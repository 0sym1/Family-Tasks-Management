<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/title_register"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="48dp" />

        <!-- Input Fields -->
        <LinearLayout
            android:id="@+id/layoutInputs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="40dp">

            <!-- Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_name"
                    android:textColor="@color/input_label"
                    android:textSize="14sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/input_border"
                    android:layout_marginEnd="12dp" />
                <EditText
                    android:id="@+id/etName"
                    style="@style/DarkEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_name"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    android:autofillHints="name"
                    android:singleLine="true" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvNameError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_email"
                    android:textColor="@color/input_label"
                    android:textSize="14sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/input_border"
                    android:layout_marginEnd="12dp" />
                <EditText
                    android:id="@+id/etEmail"
                    style="@style/DarkEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_email"
                    android:textSize="14sp"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:singleLine="true" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvEmailError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <!-- Username -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_username"
                    android:textColor="@color/input_label"
                    android:textSize="14sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/input_border"
                    android:layout_marginEnd="12dp" />
                <EditText
                    android:id="@+id/etUsername"
                    style="@style/DarkEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_username"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:autofillHints="username"
                    android:singleLine="true" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvUsernameError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <!-- Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password"
                    android:textColor="@color/input_label"
                    android:textSize="14sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/input_border"
                    android:layout_marginEnd="12dp" />
                <EditText
                    android:id="@+id/etPassword"
                    style="@style/DarkEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_password"
                    android:textSize="14sp"
                    android:inputType="textPassword"
                    android:autofillHints="password"
                    android:singleLine="true" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvPasswordError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:visibility="gone" />

            <!-- Confirm Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_confirm_password"
                    android:textColor="@color/input_label"
                    android:textSize="14sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/input_border"
                    android:layout_marginEnd="12dp" />
                <EditText
                    android:id="@+id/etConfirmPassword"
                    style="@style/DarkEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_confirm_password"
                    android:textSize="14sp"
                    android:inputType="textPassword"
                    android:autofillHints="password"
                    android:singleLine="true" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvConfirmError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:id="@+id/layoutButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="40dp"
            app:layout_constraintTop_toBottomOf="@id/layoutInputs">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:text="@string/btn_register"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:background="@drawable/bg_button_dark"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCancel"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:text="@string/btn_cancel"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:background="@drawable/bg_button_dark"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
