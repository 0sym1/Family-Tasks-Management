<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_back_button"
        android:contentDescription="Back"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/edit_repeat_title"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Lặp lại section -->
    <LinearLayout
        android:id="@+id/sectionRepeat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/repeat_label"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <RadioGroup
            android:id="@+id/rgRepeatType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/bottom_nav_color"
                android:text="@string/daily"
                android:textColor="@color/bottom_nav_color" />

            <RadioButton
                android:id="@+id/rbWeekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:checked="true"
                android:buttonTint="@color/bottom_nav_color"
                android:text="@string/weekly"
                android:textColor="@color/bottom_nav_color" />
        </RadioGroup>
    </LinearLayout>

    <!-- Chọn ngày section -->
    <LinearLayout
        android:id="@+id/sectionDays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/sectionRepeat">

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/choose_days_label"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:background="#3A3A3A" />

        <GridLayout
            android:id="@+id/gridDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4">

            <CheckBox android:id="@+id/cbMon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mon" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbTue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tue" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbWed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/wed" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbThu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/thu" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbFri" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/fri" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbSat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sat" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
            <CheckBox android:id="@+id/cbSun" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sun" android:textColor="@color/bottom_nav_color" android:buttonTint="@color/bottom_nav_color" />
        </GridLayout>
    </LinearLayout>

    <!-- Kết thúc lặp section -->
    <LinearLayout
        android:id="@+id/sectionEnd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toBottomOf="@id/sectionDays">

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/end_repeat_label"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp">

            <!-- Option 1: Never -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rbNever"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bottom_nav_color" />

                <TextView
                    android:id="@+id/tvLabelNever"
                    android:layout_width="288dp"
                    android:layout_height="wrap_content"
                    android:text="@string/never"
                    android:textColor="@color/bottom_nav_color"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Option 2: After X times -->
            <LinearLayout
                android:id="@+id/layoutAfterTimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbAfterTimes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bottom_nav_color" />

                <TextView
                    android:id="@+id/tvLabelAfter"
                    android:layout_width="46dp"
                    android:layout_height="wrap_content"
                    android:text="@string/after"
                    android:textColor="@color/bottom_nav_color"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_dark"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/btnMinus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="4dp"
                        android:text="-"
                        android:textColor="@color/bottom_nav_color"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvRepeatCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="0"
                        android:textColor="@color/bottom_nav_color"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/btnPlus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="4dp"
                        android:text="+"
                        android:textColor="@color/bottom_nav_color"
                        android:textSize="20sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLabelTimes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/times"
                    android:textColor="@color/bottom_nav_color"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Option 3: After Date -->
            <LinearLayout
                android:id="@+id/layoutAfterDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbAfterDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bottom_nav_color" />

                <TextView
                    android:id="@+id/tvLabelAfterDate"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/after_date"
                    android:textColor="@color/bottom_nav_color"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center"
                    android:paddingVertical="8dp"
                    android:text="@string/date_placeholder"
                    android:textColor="@color/bottom_nav_color"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#2C2C2C"
        android:text="@string/confirm"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@id/btnCancel" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="#2C2C2C"
        android:text="@string/cancel"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
